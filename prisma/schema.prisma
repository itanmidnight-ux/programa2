// ============================================
// RECO-TRADING - Database Schema
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- Trading Configuration ----------
model TradingConfig {
  id                String   @id @default("main")
  pair              String   @default("BTC/USDT")
  timeframe         String   @default("5m")
  riskPerTrade      Float    @default(1.0)
  maxDailyLoss      Float    @default(3.0)
  maxDrawdown       Float    @default(10.0)
  maxTradesPerDay   Int      @default(120)
  minConfidence     Float    @default(0.62)
  capitalMode       String   @default("MEDIUM") // CONSERVATIVE, MEDIUM, AGGRESSIVE
  initialCapital    Float    @default(1000.0)
  botEnabled        Boolean  @default(true)
  testnet           Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ---------- Trades ----------
model Trade {
  id            Int      @id @default(autoincrement())
  externalId    String?  @unique            // ID from exchange
  pair          String
  side          String                      // LONG, SHORT
  entryPrice    Float
  exitPrice     Float?
  quantity      Float
  pnl           Float    @default(0)
  pnlPercent    Float    @default(0)
  confidence    Float    @default(0)
  stopLoss      Float?
  takeProfit    Float?
  status        String   @default("OPEN")    // OPEN, CLOSED, CANCELLED
  signal        String   @default("HOLD")    // BUY, SELL, HOLD
  strategy      String   @default("default")
  leverage      Int      @default(1)
  exitReason    String?                     // STOP_LOSS, TAKE_PROFIT, TRAILING, MANUAL, SIGNAL
  commission    Float    @default(0)
  openedAt      DateTime @default(now())
  closedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  positions     Position[]
}

// ---------- Positions (current open) ----------
model Position {
  id            Int      @id @default(autoincrement())
  tradeId       Int      @unique
  trade         Trade    @relation(fields: [tradeId], references: [id])
  pair          String
  side          String
  entryPrice    Float
  currentPrice  Float
  quantity      Float
  unrealizedPnl Float    @default(0)
  stopLoss      Float
  takeProfit    Float
  trailingStop  Float?
  highestPrice  Float?                     // for trailing (longs)
  lowestPrice   Float?                     // for trailing (shorts)
  duration      Int      @default(0)       // seconds open
  openedAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ---------- Session Stats ----------
model Session {
  id              Int      @id @default(autoincrement())
  startedAt       DateTime @default(now())
  endedAt         DateTime?
  isActive        Boolean  @default(true)
  initialBalance  Float
  currentBalance  Float
  totalEquity     Float
  dailyPnl        Float    @default(0)
  sessionPnl      Float    @default(0)
  unrealizedPnl   Float    @default(0)
  totalTrades     Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  winRate         Float    @default(0)
  avgWin          Float    @default(0)
  avgLoss         Float    @default(0)
  profitFactor    Float    @default(0)
  expectancy      Float    @default(0)
  bestTrade       Float    @default(0)
  worstTrade      Float    @default(0)
  tradesToday     Int      @default(0)
  peakCapital     Float    @default(0)
  currentDrawdown Float    @default(0)
  winStreak       Int      @default(0)
  lossStreak      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ---------- System Logs ----------
model SystemLog {
  id        Int      @id @default(autoincrement())
  level     String                       // INFO, WARNING, ERROR
  message   String
  source    String   @default("system")  // bot, api, risk, ml, system
  createdAt DateTime @default(now())
}

// ---------- Smart Stop Events ----------
model SmartStopEvent {
  id           Int      @id @default(autoincrement())
  tradeId      Int
  pair         String
  stopType     String                   // INITIAL, TRAILING, BREAK_EVEN, PROFIT_LOCK, EMERGENCY
  previousStop Float
  newStop      Float
  triggerPrice Float?
  reason       String?
  createdAt    DateTime @default(now())
}

// ---------- ML Predictions ----------
model MLPrediction {
  id            Int      @id @default(autoincrement())
  pair          String
  direction     String                   // BUY, SELL, HOLD
  confidence    Float
  modelType     String   @default("ensemble")
  features      String?                  // JSON string of features used
  marketRegime  String?
  actualResult  String?                  // UP, DOWN, FLAT (filled after)
  correct       Boolean?
  createdAt     DateTime @default(now())
  resolvedAt    DateTime?
}

// ============================================
// Settings & Configuration Persistence
// ============================================

// ---------- App Settings (key-value store) ----------
model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @default("")
  section     String   @default("general")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------- Risk Manager Config ----------
model RiskManagerConfig {
  id                 String   @id @default("main")
  maxRiskPerTrade    Float    @default(1.0)
  maxDailyLoss       Float    @default(3.0)
  maxDrawdown        Float    @default(10.0)
  maxTradesPerDay    Int      @default(120)
  maxTradesPerHour   Int      @default(20)
  minConfidence      Float    @default(0.55)
  minRiskReward      Float    @default(1.5)
  maxSpreadPct       Float    @default(0.1)
  cooldownMinutes    Int      @default(1)
  kellyFraction      Float    @default(0.25)
  trailingStopATR    Float    @default(2.0)
  breakEvenATR       Float    @default(1.0)
  maxOpenPositions   Int      @default(1)
  emergencyStopPct   Float    @default(5.0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ---------- Smart Stop Loss Config ----------
model SmartStopLossConfig {
  id                        String   @id @default("main")
  phase1ProfitPct           Float    @default(0.5)
  phase1TrailATR            Float    @default(2.5)
  phase2ProfitPct           Float    @default(1.5)
  phase2TrailATR            Float    @default(1.8)
  phase3ProfitPct           Float    @default(3.0)
  phase3TrailATR            Float    @default(1.2)
  phase4ProfitPct           Float    @default(5.0)
  phase4TrailATR            Float    @default(0.6)
  breakEvenTriggerPct       Float    @default(0.8)
  breakEvenBuffer           Float    @default(0.001)
  profitLocks               String   @default("[]")  // JSON array
  maxHoldingMinutes         Int      @default(360)
  timeStopCheckInterval     Int      @default(30)
  unprofitableTimeLimit     Int      @default(60)
  enableMomentumStop        Boolean  @default(true)
  momentumStopMinProfit     Float    @default(0.3)
  slBufferFromSR            Float    @default(0.002)
  useResistanceAsTP         Boolean  @default(true)
  useSupportAsSL            Boolean  @default(true)
  atrPeriod                 Int      @default(14)
  atrMultiplierBase         Float    @default(2.0)
  atrMultiplierVolatility   Float    @default(3.0)
  volatilityATRPctThreshold Float    @default(2.0)
  cooldownAfterStop         Int      @default(2)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

// ---------- Smart Stop Trade Config ----------
model SmartStopTradeConfig {
  id                       String   @id @default("main")
  maxATRPct                Float    @default(4.0)
  minATRPct                Float    @default(0.15)
  minADXForTrend           Float    @default(15.0)
  maxSpreadPct             Float    @default(0.05)
  minConfluenceScore       Float    @default(0.3)
  minConfidenceGlobal      Float    @default(0.55)
  maxConsecutiveLosses     Int      @default(5)
  maxDailyLossPct          Float    @default(3.0)
  maxDrawdownPct           Float    @default(8.0)
  lossStreakReductionPct   Int      @default(20)
  lowLiquidityHours        String   @default("[0,1,2,3,4,5,6]")  // JSON array
  weekendPause             Boolean  @default(false)
  equityCurveMAPeriod      Int      @default(10)
  equityCurvePauseBelowMA  Boolean  @default(true)
  enableMLVeto             Boolean  @default(true)
  mlVetoThreshold          Float    @default(0.7)
  avoidRegimes             String   @default("[]")  // JSON array
  reducedSizeRegimes       String   @default("[\"RANGING\",\"VOLATILE\"]")  // JSON array
  reducedSizeMultiplier    Float    @default(0.5)
  autoResumeAfterMinutes   Int      @default(15)
  requireAllClear          Boolean  @default(false)
  pauseCooldownMinutes     Int      @default(5)
  resumeCheckIntervalSec   Int      @default(30)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

// ---------- Engine State ----------
model EngineState {
  id              String   @id @default("main")
  status          String   @default("STOPPED")  // RUNNING, PAUSED, STOPPED, ERROR
  uptimeSeconds   Int      @default(0)
  loopCount       Int      @default(0)
  lastLoopAt      DateTime?
  lastSignal      String?
  lastError       String?
  currentPair     String   @default("BTC/USDT")
  currentStrategy String   @default("default")
  extraState      String   @default("{}")        // JSON for extensible state
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ---------- Config Change Audit Log ----------
model ConfigChange {
  id        Int      @id @default(autoincrement())
  section   String
  key       String
  oldValue  String?
  newValue  String?
  source    String   @default("system")
  createdAt DateTime @default(now())
}

// ---------- Config Profiles ----------
model ConfigProfile {
  id          Int      @id @default(autoincrement())
  name        String
  description String   @default("")
  settings    String   @default("{}")  // JSON snapshot of all AppSettings
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------- Alert Rules ----------
model AlertRule {
  id          Int      @id @default(autoincrement())
  name        String
  condition   String   @default("{}")  // JSON condition definition
  enabled     Boolean  @default(true)
  lastTrigger DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------- Backtest Results ----------
model BacktestResult {
  id        Int      @id @default(autoincrement())
  name      String
  results   String   @default("{}")  // JSON backtest results
  createdAt DateTime @default(now())
}
