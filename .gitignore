# ============================================
# RECO-TRADING - Git Ignore
# ============================================
# SECURITY: Protect sensitive files from version control
# NEVER commit API keys, secrets, or database files
# ============================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Next.js
.next/
out/
standalone/

# Production
build/
dist/
.vercel/

# Environment variables (CRITICAL - contains API keys)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
.env.staging

# Database files (CRITICAL - contains trade data)
*.db
*.db-journal
*.db-wal
*.db-shm
data/
prisma/migrations/
prisma/*.db

# AI Trading System
models/
logs/training/
*.onnx
*.pb
*.h5

# Logs (may contain sensitive info)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
*.code-workspace

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Testing
coverage/
.nyc_output/

# Prisma generated
prisma/migrations/

# Misc
*.tsbuildinfo
next-env.d.ts

# Archives (may contain source + env)
*.zip
*.tar
*.tar.gz
*.rar

# Worklogs and internal docs
worklog*.md

# TypeScript cache
*.ts.tsbuildinfo

# Turbo
.turbo/

# PWA files (if applicable)
public/sw.js
public/workbox-*.js
public/sw.js.map
public/workbox-*.js.map

# OANDA credentials file
oanda-credentials.json
