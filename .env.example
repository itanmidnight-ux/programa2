# ============================================
# RECO-TRADING - Environment Configuration
# ============================================

# ---- DATABASE ----
DATABASE_URL=file:./data/reco_trading.db

# ---- OANDA API (Primary Broker) ----
# Get from: https://www.oanda.com/dashboard/
OANDA_ACCOUNT_ID=your_account_id_here
OANDA_API_TOKEN=your_api_token_here
OANDA_IS_DEMO=true

# ---- BROKER SELECTION ----
BROKER_ACTIVE=oanda

# ---- WELTRADE MT5 BRIDGE ----
WELTRADE_MT5_LOGIN=your_mt5_login
WELTRADE_MT5_PASSWORD=your_mt5_password
WELTRADE_MT5_SERVER=your_mt5_server
WELTRADE_MT5_IS_DEMO=true
WELTRADE_MT5_BRIDGE_URL=http://127.0.0.1:5001
WELTRADE_MT5_TIMEOUT_MS=10000

# ---- TRADING CONFIG ----
TRADING_SYMBOL=XAU_USD
PRIMARY_TIMEFRAME=5m
TICK_INTERVAL=3000

# ---- RISK MANAGEMENT ----
RISK_PER_TRADE=1.0
MAX_DAILY_LOSS=3.0
MAX_DRAWDOWN=10.0
MAX_TRADES_PER_DAY=120
MIN_CONFIDENCE=0.25

# ---- CAPITAL ----
INITIAL_CAPITAL=1000.0
CAPITAL_MODE=MEDIUM

# ---- DASHBOARD ----
DASHBOARD_PORT=3000

# ---- SESSION ----
NEXTAUTH_SECRET=change-me
NEXTAUTH_URL=http://localhost:3000
